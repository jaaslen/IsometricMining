; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Isometric"
run/main_scene="res://Scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=60
config/icon="res://Visuals/icon.svg"

[autoload]

Global="*res://Data/Global.gd"
TraitData="*res://Boosts/BoostDatabase.gd"

[display]

window/stretch/mode="viewport"
window/stretch/aspect="expand"
window/handheld/orientation=1

[gui]

timers/tooltip_delay_sec.editor_hint=0.2
theme/custom="uid://bhh6e3pgmrfbn"
theme/custom_font="uid://daivjrli5uhag"

